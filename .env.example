# Copia este archivo a .env y llena los valores reales.
# .env NUNCA se sube al repo (ver .gitignore) — cada quien lo llena localmente.
#
# De dónde sacar cada valor: Supabase Dashboard -> Project Settings -> API Keys
# (para las keys) y -> Database (para la connection string).

# URL pública del proyecto. Segura de exponer en frontend.
SUPABASE_URL=https://tolihlhldbjebxakiayu.supabase.co

# Key "anon" / "public". Segura de exponer en frontend: solo puede hacer lo
# que las políticas de RLS le permitan (por eso hay que activar RLS antes de
# usar esta key desde el navegador).
SUPABASE_ANON_KEY=

# Key "service_role". SOLO backend, nunca en frontend ni en el navegador:
# se salta RLS por completo, tiene acceso total a la base de datos.
SUPABASE_SERVICE_ROLE_KEY=

# Connection string de Postgres, para scripts/backends que hablan Postgres
# directo (ej. migration/migrate.py, un backend con SQLAlchemy). Desde
# entornos sin salida TCP directa (como este) hay que usar el REST API en su
# lugar (ver migration/migrate_rest.py).
DATABASE_URL=postgresql://postgres:PASSWORD@db.tolihlhldbjebxakiayu.supabase.co:5432/postgres
